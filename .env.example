# MyCase OAuth Credentials
# You can get these after you provide the Redirect URI and get set up by MyCase support.

MYCASE_CLIENT_ID=your_client_id_here
MYCASE_CLIENT_SECRET=your_client_secret_here
PORT=3000

# The Redirect URI you need to give MyCase support is:
# http://localhost:3000/callback (if using port 3000)

# Calendly OAuth helper (npm run calendly:redirect-uri)
CALENDLY_CLIENT_ID=2J_CZv6FGkYpr_otw4u-OZk1F_90sVeMrKh5j-PAXCI
# CALENDLY_BASE_URL=http://localhost:3000
# CALENDLY_REDIRECT_PATH=/oauth/calendly/callback
# Optional override:
# CALENDLY_AUTH_URL=https://auth.calendly.com/oauth/authorize

# Shopify Admin API — store audit (scripts/shopify-store-audit.js / npm run shopify:audit)
# SHOPIFY_SHOP=your-store.myshopify.com
# Use the same .myshopify host as your admin URL for every run (avoid mixing two aliases).
# SHOPIFY_API_VERSION=2025-10
#
# Auth: either a static Admin token OR Dev Dashboard client credentials (own store).
# SHOPIFY_ACCESS_TOKEN=shpat_xxxxxxxx
# SHOPIFY_CLIENT_ID=from_dev_dashboard_settings
# SHOPIFY_CLIENT_SECRET=from_dev_dashboard_settings
